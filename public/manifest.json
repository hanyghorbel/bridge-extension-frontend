{
  "manifest_version": 3,
  "name": "Attio LinkedIn Bridge",
  "version": "1.0.0",
  "description": "Sync LinkedIn companies directly to your Attio Workspace.",
  "permissions": [
    "activeTab",
    "storage",
    "sidePanel"
  ],
  "host_permissions": [
    "https://*.linkedin.com/*",
    "http://localhost:8080/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://*.linkedin.com/company/*"],
      "js": ["content.js"]
    }
  ],
  "side_panel": {
    "default_path": "index.html"
  },
  "action": {
    "default_title": "Open Attio Bridge"
  }
}